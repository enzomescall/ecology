# Server
NODE_ENV=production
PORT=3000

# Set to your Railway app URL (e.g. https://ecology-production.up.railway.app)
# Only needed if you want to restrict CORS explicitly
CLIENT_ORIGIN=https://your-app.up.railway.app

# Build-time env var for the client — set this in Railway service variables
# This tells the React app where the API is. Use /api/game for same-origin serving.
VITE_API_URL=/api/game

# Email (optional — without these, codes are logged to console)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
EMAIL_FROM=Ecology <noreply@yourdomain.com>
